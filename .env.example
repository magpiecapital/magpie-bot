# Telegram
TELEGRAM_BOT_TOKEN=

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
PROGRAM_ID=
LENDER_PUBKEY=

# Encryption (32-byte hex string for AES-256)
WALLET_ENCRYPTION_KEY=

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/bagbank

# Price oracle
JUPITER_API_URL=https://api.jup.ag/price/v2

# --- Liquidation backend only ---
# Provide exactly one of LENDER_PRIVATE_KEY (base58) or LENDER_KEYPAIR_PATH.
LENDER_PRIVATE_KEY=
LENDER_KEYPAIR_PATH=
# Collateral/loan ratio below which a loan gets liquidated (1.1 = 10% buffer).
LIQUIDATION_THRESHOLD=1.1
# How often (seconds) to poll all active loans.
PRICE_CHECK_INTERVAL=30

# --- Admin ---
# Comma-separated telegram user IDs with admin privileges.
ADMIN_TELEGRAM_IDS=

# --- Database SSL ---
# Set to "false" when Postgres proxy doesn't support SSL (e.g. Railway TCP proxy).
DB_SSL=false

# --- Risk Engine ---
# How often (seconds) to profile all supported tokens. Default 300.
RISK_CHECK_INTERVAL=300

# --- Credit Protocol API ---
# Port for the composable credit score REST API. Default 3001.
API_PORT=3001

# --- Tunables ---
# Deposit watcher poll interval (ms). Default 20000.
DEPOSIT_POLL_MS=
# Loan-due warning watcher interval (ms). Default 60000.
LOAN_WATCH_MS=
